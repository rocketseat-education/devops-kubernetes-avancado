{
    "app": "app-ts",
    "environment": "hmg",
    "team": "testers",
    "charts": {
        "url": "git@github.com:eusouodaniel/rocketseat.heml-charts.git",
        "revision": "main",
        "path": "charts/backend-service"
    },
    "image": {
        "repository": "danielrodrigues/app-ts"
    },
    "replicaCount": 2,
    "containerPort": 3000,
    "env": {
        "NODE_ENV": "hmg",
        "NODE_TLS_REJECT_UNAUTHORIZED": 0
    },
    "resources": {
        "requests": {
            "cpu": "100m",
            "memory": "256Mi"
        },
        "limits": {
            "cpu": "300m",
            "memory": "256Mi"
        }
    },
    "service": {
        "type": "ClusterIP",
        "port": 80
    },
    "probes": {
        "enabled": false,
        "path": "/health"
    }
}
